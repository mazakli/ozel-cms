# ─── Facebook / Instagram (Meta) ─────────────────────────────────────────────
# developers.facebook.com → Uygulamam → Ayarlar → Temel
META_APP_ID=
META_APP_SECRET=
# Redirect URI olarak eklenecek: {APP_URL}/api/sm-hesaplar/callback/facebook

# ─── Twitter / X ─────────────────────────────────────────────────────────────
# developer.twitter.com → Projects & Apps → Uygulamanız → Keys and tokens
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Redirect URI: {APP_URL}/api/sm-hesaplar/callback/twitter

# ─── Pinterest ────────────────────────────────────────────────────────────────
# developers.pinterest.com → Uygulamam
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# Redirect URI: {APP_URL}/api/sm-hesaplar/callback/pinterest

# ─── YouTube / Google ─────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI: {APP_URL}/api/sm-hesaplar/callback/youtube
